# Render cleanup candidates
render_cleanup_candidates() {
    local stale_count=0
    local repo dir touched age_days
    local has_open_work

    print_color "$BLUE" "🗑️  CLEANUP CANDIDATES (stale local repos with no open GitHub work)"
    echo

    # Build list of repos with open items
    local repos_with_work
    repos_with_work="$(awk -F '\t' '{print $3}' "$SCORED_ITEMS_FILE" | sort -u)"

    while IFS=$'\t' read -r repo dir; do
        [ -n "$repo" ] || continue
        [ -d "$dir" ] || continue

        touched="$(repo_last_touched_epoch "$dir")"
        age_days=$(( (NOW_EPOCH - touched) / 86400 ))

        if [ "$age_days" -ge "$STALE_DAYS" ]; then
            # Check if repo has open work
            has_open_work="false"
            if echo "$repos_with_work" | grep -Fxq "$repo"; then
                has_open_work="true"
            fi

            if [ "$has_open_work" = "false" ]; then
                printf "  - %s (%d days stale)\n" "$repo" "$age_days"
                printf "    %s\n" "$dir"
                stale_count=$((stale_count + 1))
            fi
        fi
    done < "$LOCAL_REPOS_FILE"

    if [ "$stale_count" -eq 0 ]; then
        echo "  (none)"
    fi
    echo
}

# Format a notification reason for display
format_notification_reason() {
    local reason="$1"
    case "$reason" in
        review_requested)    echo "review requested" ;;
        approval_requested)  echo "approval requested" ;;
        mention)             echo "mentioned" ;;
        assign)              echo "assigned" ;;
        author)              echo "your PR got activity" ;;
        manual)              echo "manually subscribed" ;;
        state_change)        echo "state changed" ;;
        ci_activity)         echo "CI activity" ;;
        subscribed)          echo "subscribed" ;;
        team_mention)        echo "team mentioned" ;;
        security_alert)      echo "security alert" ;;
        *)                   echo "$reason" ;;
    esac
}

# Convert GitHub API subject URL to a web URL
notification_web_url() {
    local api_url="$1" repo="$2" number="$3"
    [ -n "$number" ] || return 0
    if [[ "$api_url" == */pulls/* ]]; then
        echo "https://github.com/$repo/pull/$number"
    else
        echo "https://github.com/$repo/issues/$number"
    fi
}

# Render the notifications section
# Reads from CATEGORIZED_NOTIFICATIONS_FILE (TSV: tier, reason, repo, title, subject_type, thread_id, url, updated_at)
# Cross-references with SCORED_ITEMS_FILE to deduplicate items already shown in ACTION NEEDED
render_notifications() {
    if [ ! -s "$CATEGORIZED_NOTIFICATIONS_FILE" ]; then
        return 0
    fi

    local total_count
    total_count="$(wc -l < "$CATEGORIZED_NOTIFICATIONS_FILE" | tr -d ' ')"

    if [ "$total_count" -eq 0 ]; then
        return 0
    fi

    # Build set of repo+number already shown in ACTION NEEDED for dedup
    # SCORED_ITEMS_FILE columns: score, type, repo, number, title, url, author, updated_at, is_draft, my_role, last_actor, last_at, waiting_on_me, is_local
    local action_needed_keys=""
    if [ -s "$SCORED_ITEMS_FILE" ]; then
        action_needed_keys="$(awk -F '\t' '$13 == "true" { print $3 "|" $4 }' "$SCORED_ITEMS_FILE")"
    fi

    print_color "$CYAN" "📬 NOTIFICATIONS ($total_count unread)"
    echo

    # --- 🔴 ACTION NEEDED tier ---
    local action_count=0
    local tier reason repo title subject_type thread_id url updated_at
    while IFS=$'\t' read -r tier reason repo title subject_type thread_id url updated_at; do
        [ "$tier" = "action_needed" ] || continue
        [ -n "$repo" ] || continue

        # Extract number from subject URL (e.g., .../pulls/123 or .../issues/456)
        local number=""
        if [ -n "$url" ]; then
            number="${url##*/}"
        fi

        # Deduplicate: skip if already shown in ACTION NEEDED section
        if [ -n "$number" ] && [ -n "$action_needed_keys" ] && echo "$action_needed_keys" | grep -Fxq "${repo}|${number}"; then
            continue
        fi

        if [ "$action_count" -eq 0 ]; then
            printf "  ${RED}🔴 ACTION NEEDED${NC}\n"
        fi
        local reason_text
        reason_text="$(format_notification_reason "$reason")"
        local display_id="${number:+#$number}"
        local web_url
        web_url="$(notification_web_url "$url" "$repo" "$number")"
        printf "    \033]8;;%s\a${BOLD}%s${NC} %s\033]8;;\a — %s\n" "$web_url" "$repo" "$display_id" "$reason_text"
        action_count=$((action_count + 1))
    done < "$CATEGORIZED_NOTIFICATIONS_FILE"
    if [ "$action_count" -gt 0 ]; then
        echo
    fi

    # --- 🟡 YOUR STUFF tier ---
    local yours_count=0
    while IFS=$'\t' read -r tier reason repo title subject_type thread_id url updated_at; do
        [ "$tier" = "your_stuff" ] || continue
        [ -n "$repo" ] || continue

        if [ "$yours_count" -eq 0 ]; then
            printf "  ${YELLOW}🟡 YOUR STUFF${NC}\n"
        fi
        local number=""
        if [ -n "$url" ]; then
            number="${url##*/}"
        fi
        local reason_text
        reason_text="$(format_notification_reason "$reason")"
        local display_id="${number:+#$number}"
        local web_url
        web_url="$(notification_web_url "$url" "$repo" "$number")"
        printf "    \033]8;;%s\a${BOLD}%s${NC} %s\033]8;;\a — %s\n" "$web_url" "$repo" "$display_id" "$reason_text"
        yours_count=$((yours_count + 1))
    done < "$CATEGORIZED_NOTIFICATIONS_FILE"
    if [ "$yours_count" -gt 0 ]; then
        echo
    fi

    # --- 🟠 STATE CHANGES tier ---
    local state_count=0
    while IFS=$'\t' read -r tier reason repo title subject_type thread_id url updated_at; do
        [ "$tier" = "state_changes" ] || continue
        [ -n "$repo" ] || continue

        if [ "$state_count" -eq 0 ]; then
            printf "  ${YELLOW}🟠 STATE CHANGES${NC}\n"
        fi
        local number=""
        if [ -n "$url" ]; then
            number="${url##*/}"
        fi
        local reason_text
        reason_text="$(format_notification_reason "$reason")"
        local display_id="${number:+#$number}"
        local web_url
        web_url="$(notification_web_url "$url" "$repo" "$number")"
        printf "    \033]8;;%s\a${BOLD}%s${NC} %s\033]8;;\a — %s\n" "$web_url" "$repo" "$display_id" "$reason_text"
        state_count=$((state_count + 1))
    done < "$CATEGORIZED_NOTIFICATIONS_FILE"
    if [ "$state_count" -gt 0 ]; then
        echo
    fi

    # --- 🟢 NOISE tier (repo-grouped counts) ---
    local noise_lines
    noise_lines="$(awk -F '\t' '$1 == "noise" && $3 != "" { print $3 "\t" $2 }' "$CATEGORIZED_NOTIFICATIONS_FILE")"
    if [ -n "$noise_lines" ]; then
        local noise_count
        noise_count="$(echo "$noise_lines" | wc -l | tr -d ' ')"
        printf "  ${GREEN}🟢 NOISE (%d — run with --dismiss-noise to mark done)${NC}\n" "$noise_count"
        # Group by repo with count and most common reason, sorted by count descending
        echo "$noise_lines" | awk -F '\t' '
        {
            repo = $1
            reason = $2
            repo_count[repo]++
            repo_reason[repo] = reason
        }
        END {
            for (repo in repo_count) {
                printf "%d\t%s\t%s\n", repo_count[repo], repo, repo_reason[repo]
            }
        }
        ' | sort -t $'\t' -k1,1nr | while IFS=$'\t' read -r cnt rp rsn; do
            printf "    %s — %d %s\n" "$rp" "$cnt" "$rsn"
        done
        echo
    fi

    # Show nothing message if all were deduped
    local shown=$((action_count + yours_count + state_count))
    if [ "$shown" -eq 0 ] && [ -z "$noise_lines" ]; then
        echo "  (all notifications already shown in other sections)"
        echo
    fi

    # Render noisy repo suggestions
    render_noisy_repos
}

# Detect repos with high notification frequency but low user engagement
# A repo is "noisy" if it has 5+ noise-tier notifications and zero
# action_needed/your_stuff notifications in the current batch.
# Also excludes repos where the user has open PRs/issues (from SCORED_ITEMS_FILE).
# Output: TSV lines of noisy_repo\tnotification_count to stdout
detect_noisy_repos() {
    if [ ! -s "$CATEGORIZED_NOTIFICATIONS_FILE" ]; then
        return 0
    fi

    # Count noise-tier notifications per repo
    local noise_repos
    noise_repos="$(awk -F '\t' '$1 == "noise" && $3 != "" { count[$3]++ } END { for (r in count) print r "\t" count[r] }' "$CATEGORIZED_NOTIFICATIONS_FILE")"

    if [ -z "$noise_repos" ]; then
        return 0
    fi

    # Build set of repos that have action_needed or your_stuff notifications
    local engaged_repos
    engaged_repos="$(awk -F '\t' '($1 == "action_needed" || $1 == "your_stuff") && $3 != "" { print $3 }' "$CATEGORIZED_NOTIFICATIONS_FILE" | sort -u)"

    # Build set of repos where user has open PRs/issues
    local active_repos=""
    if [ -s "$SCORED_ITEMS_FILE" ]; then
        active_repos="$(awk -F '\t' '{ print $3 }' "$SCORED_ITEMS_FILE" | sort -u)"
    fi

    # Filter: keep only repos with 5+ noise notifications, zero engaged notifications, and no active work
    echo "$noise_repos" | while IFS=$'\t' read -r repo count; do
        [ -n "$repo" ] || continue
        [ "$count" -ge 5 ] || continue

        # Skip if repo has action_needed or your_stuff notifications
        if [ -n "$engaged_repos" ] && echo "$engaged_repos" | grep -Fxq "$repo"; then
            continue
        fi

        # Skip if repo has open PRs/issues involving the user
        if [ -n "$active_repos" ] && echo "$active_repos" | grep -Fxq "$repo"; then
            continue
        fi

        printf '%s\t%s\n' "$repo" "$count"
    done | sort -t $'\t' -k2,2nr
}

# Render noisy repo suggestions with unsubscribe commands
# Called at the end of render_notifications()
render_noisy_repos() {
    local noisy_repos
    noisy_repos="$(detect_noisy_repos)"

    if [ -z "$noisy_repos" ]; then
        return 0
    fi

    printf "  ${DIM}🔕 NOISY REPOS (consider unsubscribing)${NC}\n"

    local repo count node_id
    while IFS=$'\t' read -r repo count; do
        [ -n "$repo" ] || continue

        # Look up the repository node_id from the raw notifications JSON
        node_id="$(jq -r --arg repo "$repo" '
            [.[] | select(.repository.full_name == $repo)] | first | .repository.node_id // ""
        ' "$NOTIFICATIONS_FILE")"

        printf "    %s — %d noise notifications\n" "$repo" "$count"
        if [ -n "$node_id" ]; then
            printf "    ${DIM}gh api graphql -f query='mutation { updateSubscription(input: {subscribableId: \"%s\", state: IGNORED}) { subscribable { id } } }'${NC}\n" "$node_id"
        fi
    done <<< "$noisy_repos"
    echo
}

# Render local repos behind upstream (quick status)
render_local_behind() {
    local repo dir behind_count=0
    local upstream counts ahead behind branch

    print_color "$CYAN" "📥 LOCAL REPOS BEHIND UPSTREAM"
    echo

    while IFS=$'\t' read -r repo dir; do
        [ -n "$repo" ] || continue
        [ -d "$dir" ] || continue

        if [ "$FETCH" = "true" ]; then
            git -C "$dir" fetch --quiet --prune origin >/dev/null 2>&1 || true
        fi

        upstream="$(git -C "$dir" rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' 2>/dev/null || true)"
        [ -n "$upstream" ] || continue

        counts="$(git -C "$dir" rev-list --left-right --count "HEAD...$upstream" 2>/dev/null || echo "0 0")"
        ahead="${counts%% *}"
        behind="${counts##* }"

        if [ "$behind" -gt 0 ] 2>/dev/null; then
            branch="$(git -C "$dir" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "detached")"
            printf "  - %s (%s): ↓%s ↑%s\n" "$repo" "$branch" "$behind" "$ahead"
            behind_count=$((behind_count + 1))
        fi
    done < "$LOCAL_REPOS_FILE"

    if [ "$behind_count" -eq 0 ]; then
        echo "  (all up to date)"
    fi
    echo
}

# Render recent AI coding sessions (Claude Code, Codex)
render_ai_sessions() {
    local claude_dir="$HOME/.claude/projects"
    local codex_dir="$HOME/.codex/sessions"
    local session_days="${AI_SESSION_DAYS:-7}"
    local max_sessions="${AI_SESSION_MAX:-15}"

    print_color "$YELLOW" "🤖 RECENT AI CODING SESSIONS (last ${session_days} days)"
    echo

    # Collect sessions into temp file for sorting
    local sessions_tmp file_list
    sessions_tmp="$(mktemp)"
    file_list="$(mktemp)"

    # Claude Code sessions - get most recent files excluding subagents and Intent workspaces
    if [ -d "$claude_dir" ]; then
        find "$claude_dir" -name "*.jsonl" -mtime "-${session_days}" -size +1k \
            ! -path "*/subagents/*" \
            ! -path "*-intent-workspaces-*" \
            -exec stat -f '%m %N' {} \; 2>/dev/null | \
            sort -rn | head -"$max_sessions" > "$file_list"

        local claude_count
        claude_count=$(wc -l < "$file_list" | tr -d ' ')
        print_debug "Claude sessions file list: $claude_count files"

        # Process each line using fd 3 to avoid jq consuming stdin
        local line mtime_epoch f proj proj_decoded mtime_display first_msg
        while IFS= read -r line <&3; do
            mtime_epoch="${line%% *}"
            f="${line#* }"
            [ -n "$f" ] || continue
            [ -f "$f" ] || continue

            # Get project path from directory name
            proj=$(dirname "$f" | sed 's|.*/projects/||')
            proj_decoded=$(echo "$proj" | sed 's|^-|/|' | tr '-' '/')

            # Get display time
            mtime_display=$(stat -f '%Sm' -t '%Y-%m-%d %H:%M' "$f" 2>/dev/null || echo "unknown")

            # Get first user message - quick extraction (|| true to handle empty files gracefully)
            first_msg=$(
                grep -m1 -E '"type":"(user|human)"' "$f" 2>/dev/null | \
                jq -r '(if .message.content | type == "array" then .message.content[0].text else .message.content end) // ""' 2>/dev/null | \
                head -c 150 | tr '\n\t' '  '
            ) || true

            # Skip system prompts, interrupts, and empty messages
            case "$first_msg" in
                *"# Your Specialist Role"*|*"<specialist_role>"*|*"Role Reminder:"*)
                    continue
                    ;;
                "[Request interrupted"*|"<local-command-caveat>"*|"")
                    continue
                    ;;
            esac

            if [ ${#first_msg} -gt 5 ]; then
                printf '%s\t%s\t%s\t%s\t%s\n' "$mtime_epoch" "$mtime_display" "claude" "$proj_decoded" "${first_msg:0:100}" >> "$sessions_tmp"
            fi
        done 3< "$file_list"
    fi

    # Codex sessions - get most recent files
    if [ -d "$codex_dir" ]; then
        find "$codex_dir" -name "*.jsonl" -mtime "-${session_days}" -size +1k \
            -exec stat -f '%m %N' {} \; 2>/dev/null | \
            sort -rn | head -"$max_sessions" > "$file_list"

        local codex_count
        codex_count=$(wc -l < "$file_list" | tr -d ' ')
        print_debug "Codex sessions file list: $codex_count files"

        local line mtime_epoch f mtime_display cwd first_msg
        while IFS= read -r line <&3; do
            mtime_epoch="${line%% *}"
            f="${line#* }"
            [ -n "$f" ] || continue
            [ -f "$f" ] || continue

            # Get display time
            mtime_display=$(stat -f '%Sm' -t '%Y-%m-%d %H:%M' "$f" 2>/dev/null || echo "unknown")

            # Get session metadata (first line) and first user message
            cwd=$(head -1 "$f" 2>/dev/null | jq -r '.payload.cwd // ""' 2>/dev/null) || true
            first_msg=$(grep -m1 '"role":"user"' "$f" 2>/dev/null | jq -r '.payload.content[0].text // ""' 2>/dev/null | head -c 100 | tr '\n\t' '  ') || true

            # Skip system prompts
            case "$first_msg" in
                "# AGENTS.md"*|*"<INSTRUCTIONS>"*)
                    continue
                    ;;
            esac

            if [ -n "$cwd" ] && [ "$cwd" != "null" ] && [ -n "$first_msg" ] && [ "$first_msg" != "null" ] && [ ${#first_msg} -gt 5 ]; then
                printf '%s\t%s\t%s\t%s\t%s\n' "$mtime_epoch" "$mtime_display" "codex" "$cwd" "$first_msg" >> "$sessions_tmp"
            fi
        done 3< "$file_list"
    fi

    rm -f "$file_list"

    print_debug "Total sessions collected: $(wc -l < "$sessions_tmp" 2>/dev/null || echo 0)"

    # Sort by time (newest first) and display
    local session_count=0
    if [ -s "$sessions_tmp" ]; then
        while IFS=$'\t' read -r _ mtime_display tool proj first_msg; do
            local tool_icon
            case "$tool" in
                claude) tool_icon="🟠" ;;
                codex)  tool_icon="🟢" ;;
                *)      tool_icon="⚪" ;;
            esac
            printf "  ${DIM}%s${NC} %s %s\n" "$mtime_display" "$tool_icon" "$tool"
            printf "    📁 %s\n" "$proj"
            printf "    💬 %s...\n" "${first_msg:0:70}"
            echo
            session_count=$((session_count + 1))
        done < <(sort -t $'\t' -k1,1nr "$sessions_tmp" | head -15)
    fi

    rm -f "$sessions_tmp"

    if [ "$session_count" -eq 0 ]; then
        echo "  (no recent AI sessions found)"
    else
        echo "  ${DIM}Resume with: claude --resume or codex resume${NC}"
    fi
    echo
}

# Fetch all unread GitHub notifications
# Output: raw JSON array written to NOTIFICATIONS_FILE
fetch_notifications() {
    print_debug "Fetching notifications..."

    local raw_json
    raw_json="$(gh api notifications --method GET \
        -F all=false \
        -F per_page=50 \
        --paginate 2>/dev/null)" || {
        print_warn "Failed to fetch GitHub notifications. Check your authentication (gh auth status)."
        raw_json="[]"
    }

    # --paginate returns one JSON array per page; merge them
    printf '%s' "$raw_json" | jq -s 'add // []' > "$NOTIFICATIONS_FILE"

    local count
    count="$(jq 'length' "$NOTIFICATIONS_FILE")"
    print_debug "Fetched $count notifications"
}

# Categorize notifications by reason into four tiers
# Reads NOTIFICATIONS_FILE, outputs TSV to stdout:
#   tier|reason|repo|title|subject_type|thread_id|url|updated_at
# Tiers: action_needed, your_stuff, state_changes, noise
categorize_notifications() {
    jq -r '
        def tier:
            if . == "review_requested" or . == "mention" or . == "assign" or . == "approval_requested" then
                "action_needed"
            elif . == "author" or . == "manual" then
                "your_stuff"
            elif . == "state_change" or . == "ci_activity" then
                "state_changes"
            else
                "noise"
            end;

        .[] | [
            (.reason | tier),
            .reason,
            .repository.full_name,
            .subject.title,
            .subject.type,
            .id,
            (.subject.url // ""),
            .updated_at
        ] | @tsv
    ' "$NOTIFICATIONS_FILE"
}

# Check if auth token supports the notifications API
# Fine-grained PATs (github_pat_) don't support notifications; classic PATs (ghp_) and OAuth tokens do
check_auth_token() {
    local token
    token="$(gh auth token 2>/dev/null || true)"

    if [ -z "$token" ]; then
        print_warn "Could not detect auth token. Notification operations may fail."
        return 0
    fi

    case "$token" in
        github_pat_*)
            print_warn "Fine-grained PAT detected — notifications API requires a classic token (ghp_) or OAuth token."
            print_warn "Notification dismiss/mark-done operations will likely fail."
            ;;
        ghs_*)
            print_warn "GitHub App token detected — notifications API requires a user token."
            print_warn "Notification dismiss/mark-done operations will likely fail."
            ;;
    esac
}

# Mark all noise-tier notifications as done
# Reads from CATEGORIZED_NOTIFICATIONS_FILE (TSV: tier, reason, repo, title, subject_type, thread_id, url, updated_at)
dismiss_noise_notifications() {
    if [ ! -s "$CATEGORIZED_NOTIFICATIONS_FILE" ]; then
        echo "No categorized notifications found. Run without --dismiss-noise first to fetch notifications."
        return 0
    fi

    local noise_ids=()
    local tier reason repo title subject_type thread_id url updated_at
    while IFS=$'\t' read -r tier reason repo title subject_type thread_id url updated_at; do
        [ "$tier" = "noise" ] || continue
        [ -n "$thread_id" ] || continue
        noise_ids+=("$thread_id")
    done < "$CATEGORIZED_NOTIFICATIONS_FILE"

    local count=${#noise_ids[@]}
    if [ "$count" -eq 0 ]; then
        echo "No noise-tier notifications to dismiss."
        return 0
    fi

    printf "Marking %d noise notifications as done...\n" "$count"

    local dismissed=0 failed=0
    for thread_id in "${noise_ids[@]}"; do
        if (AMI_PASSTHROUGH= gh api --method DELETE "notifications/threads/$thread_id" 2>/dev/null); then
            dismissed=$((dismissed + 1))
        else
            failed=$((failed + 1))
            print_warn "Failed to dismiss thread $thread_id"
        fi
    done

    printf "Done: %d dismissed" "$dismissed"
    if [ "$failed" -gt 0 ]; then
        printf ", %d failed" "$failed"
    fi
    printf "\n"
}

# Mark specific notification threads as done
# Args: space-separated thread IDs in MARK_DONE_THREADS
mark_done_threads() {
    local ids_string="$1"
    local ids=()
    read -r -a ids <<< "$ids_string"

    local count=${#ids[@]}
    if [ "$count" -eq 0 ]; then
        return 0
    fi

    printf "Marking %d notification(s) as done...\n" "$count"

    local dismissed=0 failed=0
    for thread_id in "${ids[@]}"; do
        if (AMI_PASSTHROUGH= gh api --method DELETE "notifications/threads/$thread_id" 2>/dev/null); then
            dismissed=$((dismissed + 1))
        else
            failed=$((failed + 1))
            print_warn "Failed to dismiss thread $thread_id"
        fi
    done

    printf "Done: %d dismissed" "$dismissed"
    if [ "$failed" -gt 0 ]; then
        printf ", %d failed" "$failed"
    fi
    printf "\n"
}

main() {
    while [ $# -gt 0 ]; do
        case "$1" in
            --no-fetch)
                FETCH=false
                ;;
            --fetch)
                FETCH=true
                ;;
            --notifications)
                NOTIFICATIONS=true
                ;;
            --no-notifications)
                NOTIFICATIONS=false
                ;;
            --dismiss-noise)
                DISMISS_NOISE=true
                NOTIFICATIONS=true
                ;;
            --mark-done)
                shift
                if [ $# -eq 0 ]; then
                    print_error "--mark-done requires at least one thread ID"
                    exit 2
                fi
                while [ $# -gt 0 ] && [[ "$1" != --* ]]; do
                    if [ -n "$MARK_DONE_THREADS" ]; then
                        MARK_DONE_THREADS="$MARK_DONE_THREADS $1"
                    else
                        MARK_DONE_THREADS="$1"
                    fi
                    shift
                done
                if [ -z "$MARK_DONE_THREADS" ]; then
                    printf '%b\n' "${RED}Error:${NC} --mark-done requires at least one thread ID" >&2
                    exit 1
                fi
                continue
                ;;
            --jobs)
                shift
                if [ $# -eq 0 ]; then
                    print_error "--jobs requires a value"
                    exit 2
                fi
                JOBS="$1"
                ;;
            --max-depth)
                shift
                if [ $# -eq 0 ]; then
                    print_error "--max-depth requires a value"
                    exit 2
                fi
                FIND_MAX_DEPTH="$1"
                ;;
            --days)
                shift
                if [ $# -eq 0 ]; then
                    print_error "--days requires a value"
                    exit 2
                fi
                LOOKBACK_DAYS="$1"
                ;;
            --stale-days)
                shift
                if [ $# -eq 0 ]; then
                    print_error "--stale-days requires a value"
                    exit 2
                fi
                STALE_DAYS="$1"
                ;;
            --reset-week-cache)
                RESET_WEEK_CACHE=true
                ;;
            --no-cache)
                USE_REPO_CACHE=false
                ;;
            --cache-ttl)
                shift
                if [ $# -eq 0 ]; then
                    print_error "--cache-ttl requires a value"
                    exit 2
                fi
                REPO_CACHE_TTL="$1"
                ;;
            --limit)
                shift
                if [ $# -eq 0 ]; then
                    print_error "--limit requires a value"
                    exit 2
                fi
                LIMIT="$1"
                ;;
            --roots)
                shift
                if [ $# -eq 0 ]; then
                    print_error "--roots requires a value"
                    exit 2
                fi
                ROOTS="$1"
                ;;
            --debug)
                DEBUG=true
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                print_error "unknown option: $1"
                usage
                exit 2
                ;;
        esac
        shift
    done

    if ! [[ "$LIMIT" =~ ^[0-9]+$ ]]; then
        print_error "limit must be a positive integer"
        exit 2
    fi

    if ! [[ "$JOBS" =~ ^[0-9]+$ ]] || [ "$JOBS" -lt 1 ]; then
        print_error "jobs must be a positive integer"
        exit 2
    fi

    if ! [[ "$FIND_MAX_DEPTH" =~ ^[0-9]+$ ]] || [ "$FIND_MAX_DEPTH" -lt 1 ]; then
        print_error "max depth must be a positive integer"
        exit 2
    fi

    if ! [[ "$LOOKBACK_DAYS" =~ ^[0-9]+$ ]] || [ "$LOOKBACK_DAYS" -lt 1 ]; then
        print_error "days must be a positive integer"
        exit 2
    fi

    if ! [[ "$STALE_DAYS" =~ ^[0-9]+$ ]] || [ "$STALE_DAYS" -lt 1 ]; then
        print_error "stale days must be a positive integer"
        exit 2
    fi

    if ! [[ "$REPO_CACHE_TTL" =~ ^[0-9]+$ ]]; then
        print_error "cache TTL must be a non-negative integer"
        exit 2
    fi

    if is_true "$FETCH"; then
        FETCH=true
    else
        FETCH=false
    fi

    if is_true "$NOTIFICATIONS"; then
        NOTIFICATIONS=true
    else
        NOTIFICATIONS=false
    fi

    # --dismiss-noise requires notifications even if --no-notifications was passed
    if [ "$DISMISS_NOISE" = "true" ] && [ "$NOTIFICATIONS" = "false" ]; then
        NOTIFICATIONS=true
        print_debug "--dismiss-noise overrides --no-notifications"
    fi

    if ! resolve_gh_binary; then
        print_error "could not find gh binary"
        exit 1
    fi

    if ! command_exists git; then
        print_error "git is required"
        exit 1
    fi

    if [ -z "$ROOTS" ]; then
        ROOTS="$(default_roots)"
    fi

    # Check for jq dependency
    if ! command_exists jq; then
        print_error "jq is required for JSON processing"
        exit 1
    fi

    # Check auth token if write operations are requested
    if [ "$DISMISS_NOISE" = "true" ] || [ -n "$MARK_DONE_THREADS" ]; then
        check_auth_token
    fi

    # Handle --mark-done early (no triage needed)
    if [ -n "$MARK_DONE_THREADS" ]; then
        mark_done_threads "$MARK_DONE_THREADS"
        if [ "$DISMISS_NOISE" != "true" ]; then
            exit 0
        fi
    fi

    # Create temp files
    LOCAL_REPOS_FILE="$(mktemp -t gh-monday.local.XXXXXX)"
    REPO_STATE_FILE="$(mktemp -t gh-monday.repostate.XXXXXX)"
    GITHUB_ITEMS_FILE="$(mktemp -t gh-monday.github.XXXXXX)"
    ENRICHED_ITEMS_FILE="$(mktemp -t gh-monday.enriched.XXXXXX)"
    SCORED_ITEMS_FILE="$(mktemp -t gh-monday.scored.XXXXXX)"
    NOTIFICATIONS_FILE="$(mktemp -t gh-monday.notifications.XXXXXX)"
    CATEGORIZED_NOTIFICATIONS_FILE="$(mktemp -t gh-monday.catnotif.XXXXXX)"
    trap cleanup EXIT

    init_time_window

    # Get current user
    print_debug "Getting current user..."
    MY_USERNAME="$(get_my_username)"
    if [ -z "$MY_USERNAME" ]; then
        print_error "Could not determine GitHub username. Are you logged in? (gh auth status)"
        exit 1
    fi
    print_debug "Logged in as: $MY_USERNAME"

    # Phase 1: Discover local repos
    print_debug "Phase 1: Discovering local repositories..."
    if ! load_repo_cache; then
        scan_local_repos
        save_repo_cache
    fi
    local_repo_count="$(wc -l < "$LOCAL_REPOS_FILE" | tr -d ' ')"
    print_debug "Found $local_repo_count local repos"

    # Phase 2: Fetch GitHub items
    print_debug "Phase 2: Fetching GitHub items..."
    fetch_github_items > "$GITHUB_ITEMS_FILE"
    github_item_count="$(wc -l < "$GITHUB_ITEMS_FILE" | tr -d ' ')"
    print_debug "Found $github_item_count GitHub items"

    # Phase 2b: Fetch and categorize notifications
    if [ "$NOTIFICATIONS" = "true" ]; then
        print_debug "Phase 2b: Fetching notifications..."
        fetch_notifications
        local notif_count
        notif_count="$(jq 'length' "$NOTIFICATIONS_FILE")"
        print_debug "Found $notif_count notifications"

        print_debug "Categorizing notifications..."
        categorize_notifications > "$CATEGORIZED_NOTIFICATIONS_FILE"
        print_debug "Categorization complete"

        # Dismiss noise if requested
        if [ "$DISMISS_NOISE" = "true" ]; then
            dismiss_noise_notifications
        fi
    fi

    # Phase 3: Enrich with last actor
    print_debug "Phase 3: Enriching with last actor info..."
    enrich_with_last_actor > "$ENRICHED_ITEMS_FILE"
    print_debug "Enrichment complete"

    # Phase 4: Score and rank
    print_debug "Phase 4: Scoring and ranking..."
    score_items > "$SCORED_ITEMS_FILE"
    print_debug "Scoring complete"

    # Output header
    print_color "$GREEN" "═══════════════════════════════════════════════════════════════"
    print_color "$GREEN" "  GitHub Triage - $(date '+%Y-%m-%d %H:%M')"
    print_color "$GREEN" "═══════════════════════════════════════════════════════════════"
    print_color "$DIM" "  user: @$MY_USERNAME | local repos: $local_repo_count | items: $github_item_count"
    if [ "$DEBUG" = "true" ]; then
        print_color "$DIM" "  roots: $ROOTS"
        print_color "$DIM" "  lookback: $LOOKBACK_DAYS days | cutoff: $(epoch_to_text "$EVENT_CUTOFF_EPOCH")"
    fi

    # Render sections
    render_action_needed
    render_waiting_on_others
    if [ "$NOTIFICATIONS" = "true" ]; then
        render_notifications
    fi
    render_local_behind
    render_ai_sessions
    render_cleanup_candidates
}

main "$@"
