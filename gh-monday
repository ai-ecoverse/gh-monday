#!/bin/bash

# gh-monday - local-first Monday morning GitHub triage
# Install as a gh extension and run with: gh monday

set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
WHITE='\033[0;37m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m' # No Color

# Runtime configuration
DEBUG="${GH_MONDAY_DEBUG:-false}"
GH_REAL_BIN="${GH_REAL_BIN:-/opt/homebrew/bin/gh}"
LIMIT="${GH_MONDAY_LIMIT:-120}"
ROOTS="${GH_MONDAY_ROOTS:-}"
FETCH="${GH_MONDAY_FETCH:-false}"
JOBS="${GH_MONDAY_JOBS:-8}"
USE_REPO_CACHE=true
REPO_CACHE_TTL="${GH_MONDAY_REPO_CACHE_TTL:-21600}"
FIND_MAX_DEPTH="${GH_MONDAY_MAX_DEPTH:-6}"
LOOKBACK_DAYS="${GH_MONDAY_DAYS:-7}"
STALE_DAYS="${GH_MONDAY_STALE_DAYS:-30}"
RESET_WEEK_CACHE=false
LAST_ACTOR_CACHE_TTL="${GH_MONDAY_ACTOR_CACHE_TTL:-3600}"

# Current user (will be populated)
MY_USERNAME=""

# Computed time window
NOW_EPOCH=0
LOOKBACK_CUTOFF_EPOCH=0
EVENT_CUTOFF_EPOCH=0
WEEK_FIRST_RUN_EPOCH=0
WEEK_FIRST_RUN_IS_NEW=false
WEEK_KEY=""

# Temp files for data collection
LOCAL_REPOS_FILE=""
REPO_STATE_FILE=""
GITHUB_ITEMS_FILE=""
ENRICHED_ITEMS_FILE=""
SCORED_ITEMS_FILE=""

# Cache directories
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/gh-monday"
CACHE_REPOS_FILE="$CACHE_DIR/local-repos.tsv"
CACHE_ROOTS_FILE="$CACHE_DIR/local-repos.roots"
CACHE_WEEKLY_FILE="$CACHE_DIR/weekly-first-run.tsv"
CACHE_ACTOR_DIR="$CACHE_DIR/last-actor"

cache_key() {
    printf '%s|%s\n' "$ROOTS" "$FIND_MAX_DEPTH"
}

print_color() {
    local color="$1"
    shift
    printf "${color}%s${NC}\n" "$*"
}

print_debug() {
    if [ "$DEBUG" = "true" ]; then
        print_color "$BLUE" "[DEBUG] $*"
    fi
}

print_warn() {
    print_color "$YELLOW" "[WARN] $*" >&2
}

print_error() {
    print_color "$RED" "[ERROR] $*" >&2
}

command_exists() {
    command -v "$1" >/dev/null 2>&1
}

cleanup() {
    rm -f "$LOCAL_REPOS_FILE" "$REPO_STATE_FILE" "$GITHUB_ITEMS_FILE" "$ENRICHED_ITEMS_FILE" "$SCORED_ITEMS_FILE"
}

resolve_gh_binary() {
    if [ -x "$GH_REAL_BIN" ]; then
        return 0
    fi

    if command_exists gh; then
        GH_REAL_BIN="$(command -v gh)"
        return 0
    fi

    return 1
}

default_roots() {
    local result=""
    local candidate

    for candidate in \
        "$HOME/Developer" \
        "$HOME/src" \
        "$HOME/code" \
        "$HOME/dev" \
        "$HOME/work" \
        "$HOME/projects"
    do
        if [ -d "$candidate" ]; then
            if [ -z "$result" ]; then
                result="$candidate"
            else
                result="$result:$candidate"
            fi
        fi
    done

    if [ -z "$result" ]; then
        result="$PWD"
    fi

    echo "$result"
}

parse_github_repo() {
    local remote="${1:-}"
    remote="${remote%.git}"

    case "$remote" in
        git@github.com:*)
            echo "${remote#git@github.com:}"
            ;;
        ssh://git@github.com/*)
            echo "${remote#ssh://git@github.com/}"
            ;;
        https://github.com/*)
            echo "${remote#https://github.com/}"
            ;;
        http://github.com/*)
            echo "${remote#http://github.com/}"
            ;;
        git://github.com/*)
            echo "${remote#git://github.com/}"
            ;;
        *)
            echo ""
            ;;
    esac
}

file_mtime() {
    local file="$1"
    stat -f %m "$file" 2>/dev/null || stat -c %Y "$file" 2>/dev/null || echo 0
}

is_true() {
    case "${1:-}" in
        true|TRUE|1|yes|YES)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

epoch_to_text() {
    local epoch="$1"
    date -r "$epoch" '+%Y-%m-%d %H:%M' 2>/dev/null || date -d "@$epoch" '+%Y-%m-%d %H:%M' 2>/dev/null || echo "$epoch"
}

current_week_key() {
    date '+%G-W%V' 2>/dev/null || date '+%Y-W%U'
}

max_int() {
    local a="$1"
    local b="$2"
    if [ "$a" -ge "$b" ]; then
        echo "$a"
    else
        echo "$b"
    fi
}

init_time_window() {
    local cache_week cache_epoch

    NOW_EPOCH="$(date +%s)"
    LOOKBACK_CUTOFF_EPOCH=$((NOW_EPOCH - (LOOKBACK_DAYS * 86400)))
    WEEK_KEY="$(current_week_key)"

    mkdir -p "$CACHE_DIR"
    if [ "$RESET_WEEK_CACHE" = "true" ]; then
        rm -f "$CACHE_WEEKLY_FILE"
    fi

    if [ -f "$CACHE_WEEKLY_FILE" ]; then
        cache_week="$(awk -F '\t' 'NR==1{print $1}' "$CACHE_WEEKLY_FILE" 2>/dev/null || true)"
        cache_epoch="$(awk -F '\t' 'NR==1{print $2}' "$CACHE_WEEKLY_FILE" 2>/dev/null || true)"
        if [ "$cache_week" = "$WEEK_KEY" ] && [[ "$cache_epoch" =~ ^[0-9]+$ ]]; then
            WEEK_FIRST_RUN_EPOCH="$cache_epoch"
            WEEK_FIRST_RUN_IS_NEW=false
        else
            WEEK_FIRST_RUN_EPOCH="$NOW_EPOCH"
            WEEK_FIRST_RUN_IS_NEW=true
            printf '%s\t%s\n' "$WEEK_KEY" "$WEEK_FIRST_RUN_EPOCH" > "$CACHE_WEEKLY_FILE"
        fi
    else
        WEEK_FIRST_RUN_EPOCH="$NOW_EPOCH"
        WEEK_FIRST_RUN_IS_NEW=true
        printf '%s\t%s\n' "$WEEK_KEY" "$WEEK_FIRST_RUN_EPOCH" > "$CACHE_WEEKLY_FILE"
    fi

    if [ "$WEEK_FIRST_RUN_IS_NEW" = "true" ]; then
        # First run this week: show the rolling lookback window.
        EVENT_CUTOFF_EPOCH="$LOOKBACK_CUTOFF_EPOCH"
    else
        EVENT_CUTOFF_EPOCH="$(max_int "$LOOKBACK_CUTOFF_EPOCH" "$WEEK_FIRST_RUN_EPOCH")"
    fi
}

repo_last_touched_epoch() {
    local repo_dir="$1"
    local git_dir mtime max_mtime last_commit_epoch

    git_dir="$(git -C "$repo_dir" rev-parse --absolute-git-dir 2>/dev/null || echo "$repo_dir/.git")"
    max_mtime=0

    for candidate in \
        "$git_dir/index" \
        "$git_dir/logs/HEAD" \
        "$git_dir/FETCH_HEAD" \
        "$git_dir/HEAD"
    do
        if [ -e "$candidate" ]; then
            mtime="$(file_mtime "$candidate")"
            if [ "$mtime" -gt "$max_mtime" ] 2>/dev/null; then
                max_mtime="$mtime"
            fi
        fi
    done

    if [ "$max_mtime" -gt 0 ] 2>/dev/null; then
        echo "$max_mtime"
        return 0
    fi

    last_commit_epoch="$(git -C "$repo_dir" log -1 --format=%ct 2>/dev/null || echo 0)"
    echo "${last_commit_epoch:-0}"
}

usage() {
    cat <<'EOF'
Usage: gh monday [options]

Ranked GitHub triage - shows what needs your attention, prioritized by:
  - Items waiting on you (someone else acted last)
  - Your local repositories (work you're actively doing)
  - Your role (author > reviewer > mentioned)
  - Recency of activity

Output sections:
  🔴 ACTION NEEDED    - PRs/issues where ball is in your court
  🟡 WAITING ON OTHERS - Your work waiting on someone else
  🗑️  CLEANUP CANDIDATES - Stale local repos with no open GitHub work

Options:
  --fetch         Fetch remotes before behind/ahead checks (slower, freshest counts)
  --no-fetch      Do not fetch remotes before behind/ahead checks
  --jobs N        Parallelism for checks (default: 8)
  --max-depth N   Max directory depth when scanning for local repos (default: 6)
  --days N        Rolling lookback window in days for activity (default: 7)
  --stale-days N  Suggest cleanup for local repos untouched for N days (default: 30)
  --reset-week-cache  Start a new weekly baseline now
  --no-cache      Disable local-repo discovery cache
  --cache-ttl S   Cache TTL in seconds for repo discovery (default: 21600)
  --limit N       Max search results fetched per section (default: 120)
  --roots A:B:C   Colon-separated local roots to scan for repositories
  --debug         Enable debug output
  -h, --help      Show this help

Environment:
  GH_REAL_BIN       gh binary path (default: /opt/homebrew/bin/gh)
  GH_MONDAY_ROOTS   Default roots (same format as --roots)
  GH_MONDAY_LIMIT   Default limit (same as --limit)
  GH_MONDAY_FETCH   true/false default fetch behavior (default: false)
  GH_MONDAY_JOBS    Parallel workers (default: 8)
  GH_MONDAY_MAX_DEPTH  Max scan depth for repo discovery (default: 6)
  GH_MONDAY_DAYS    Rolling lookback window in days (default: 7)
  GH_MONDAY_STALE_DAYS  Stale repo threshold in days (default: 30)
  GH_MONDAY_REPO_CACHE_TTL  Repo cache TTL in seconds (default: 21600)
  GH_MONDAY_ACTOR_CACHE_TTL  Last-actor cache TTL in seconds (default: 3600)
  GH_MONDAY_DEBUG   Set to true for debug output
EOF
}

repo_is_local() {
    local repo="$1"
    grep -Fq "$(printf '%s\t' "$repo")" "$LOCAL_REPOS_FILE"
}

get_local_path() {
    local repo="$1"
    awk -F '\t' -v r="$repo" '$1 == r {print $2; exit}' "$LOCAL_REPOS_FILE"
}

get_my_username() {
    "$GH_REAL_BIN" api user --jq '.login' 2>/dev/null || echo ""
}

# Fetch all GitHub items involving the user
# Output format: type|repo|number|title|url|author|updated_at|is_draft|my_role
fetch_github_items() {
    local prs_authored prs_review_requested prs_assigned issues_involving
    local tmp_prs tmp_issues

    tmp_prs="$(mktemp)"
    tmp_issues="$(mktemp)"

    print_debug "Fetching PRs authored by me..."
    prs_authored="$("$GH_REAL_BIN" search prs \
        --author=@me \
        --state=open \
        --limit "$LIMIT" \
        --json repository,number,title,url,author,updatedAt,isDraft 2>/dev/null || echo "[]")"

    print_debug "Fetching PRs where review requested..."
    prs_review_requested="$("$GH_REAL_BIN" search prs \
        --review-requested=@me \
        --state=open \
        --limit "$LIMIT" \
        --json repository,number,title,url,author,updatedAt,isDraft 2>/dev/null || echo "[]")"

    print_debug "Fetching PRs assigned to me..."
    prs_assigned="$("$GH_REAL_BIN" search prs \
        --assignee=@me \
        --state=open \
        --limit "$LIMIT" \
        --json repository,number,title,url,author,updatedAt,isDraft 2>/dev/null || echo "[]")"

    print_debug "Fetching issues involving me..."
    issues_involving="$("$GH_REAL_BIN" search issues \
        --involves=@me \
        --state=open \
        --limit "$LIMIT" \
        --json repository,number,title,url,author,updatedAt 2>/dev/null || echo "[]")"

    # Process PRs - determine role for each
    # Priority: author > reviewer > assignee
    # Filter by activity window cutoff
    printf '%s' "$prs_authored" | jq -r --arg me "$MY_USERNAME" --argjson cutoff "$EVENT_CUTOFF_EPOCH" '
        .[] | select((.updatedAt | fromdateiso8601) >= $cutoff) | [
            "pr",
            .repository.nameWithOwner,
            .number,
            .title,
            .url,
            .author.login,
            .updatedAt,
            (if .isDraft then "true" else "false" end),
            "author"
        ] | @tsv
    ' >> "$tmp_prs" 2>/dev/null || true

    printf '%s' "$prs_review_requested" | jq -r --arg me "$MY_USERNAME" --argjson cutoff "$EVENT_CUTOFF_EPOCH" '
        .[] | select((.updatedAt | fromdateiso8601) >= $cutoff) | [
            "pr",
            .repository.nameWithOwner,
            .number,
            .title,
            .url,
            .author.login,
            .updatedAt,
            (if .isDraft then "true" else "false" end),
            "reviewer"
        ] | @tsv
    ' >> "$tmp_prs" 2>/dev/null || true

    printf '%s' "$prs_assigned" | jq -r --arg me "$MY_USERNAME" --argjson cutoff "$EVENT_CUTOFF_EPOCH" '
        .[] | select(.author.login != $me) | select((.updatedAt | fromdateiso8601) >= $cutoff) | [
            "pr",
            .repository.nameWithOwner,
            .number,
            .title,
            .url,
            .author.login,
            .updatedAt,
            (if .isDraft then "true" else "false" end),
            "assignee"
        ] | @tsv
    ' >> "$tmp_prs" 2>/dev/null || true

    # Process issues - filter by activity window
    printf '%s' "$issues_involving" | jq -r --arg me "$MY_USERNAME" --argjson cutoff "$EVENT_CUTOFF_EPOCH" '
        .[] | select((.updatedAt | fromdateiso8601) >= $cutoff) | [
            "issue",
            .repository.nameWithOwner,
            .number,
            .title,
            .url,
            .author.login,
            .updatedAt,
            "false",
            (if .author.login == $me then "author" else "involved" end)
        ] | @tsv
    ' >> "$tmp_issues" 2>/dev/null || true

    # Deduplicate by repo+number, keeping highest priority role
    # Role priority: author=1, reviewer=2, assignee=3, involved=4
    cat "$tmp_prs" "$tmp_issues" | awk -F '\t' '
    BEGIN { OFS="\t" }
    {
        key = $1 "|" $2 "|" $3
        role = $9
        role_priority = (role == "author" ? 1 : (role == "reviewer" ? 2 : (role == "assignee" ? 3 : 4)))
        if (!(key in seen) || role_priority < seen_priority[key]) {
            seen[key] = $0
            seen_priority[key] = role_priority
        }
    }
    END {
        for (key in seen) print seen[key]
    }
    ' | sort -t $'\t' -k7,7r  # Sort by updatedAt descending

    rm -f "$tmp_prs" "$tmp_issues"
}

# Get last actor for a PR or issue (with caching)
# Args: type repo number updated_at
# Output: last_actor_login|last_actor_timestamp
get_last_actor() {
    local item_type="$1"
    local repo="$2"
    local number="$3"
    local updated_at="$4"

    local cache_dir="$CACHE_ACTOR_DIR/${repo//\//_}"
    local cache_file="$cache_dir/${item_type}_${number}.json"
    local cache_updated cached_actor cached_at

    mkdir -p "$cache_dir"

    # Check cache
    if [ -f "$cache_file" ]; then
        cache_updated="$(jq -r '.updated_at // ""' "$cache_file" 2>/dev/null || true)"
        if [ "$cache_updated" = "$updated_at" ]; then
            cached_actor="$(jq -r '.last_actor // ""' "$cache_file" 2>/dev/null || true)"
            cached_at="$(jq -r '.last_at // ""' "$cache_file" 2>/dev/null || true)"
            if [ -n "$cached_actor" ]; then
                printf '%s\t%s\n' "$cached_actor" "$cached_at"
                return 0
            fi
        fi
    fi

    # Fetch from API
    local last_actor="" last_at=""

    if [ "$item_type" = "pr" ]; then
        # For PRs, check both comments and reviews, get most recent
        local comments_data reviews_data

        comments_data="$("$GH_REAL_BIN" api "repos/$repo/issues/$number/comments" \
            --jq 'if length > 0 then .[-1] | {actor: .user.login, at: .created_at} else {actor: "", at: ""} end' 2>/dev/null || echo '{}')"

        reviews_data="$("$GH_REAL_BIN" api "repos/$repo/pulls/$number/reviews" \
            --jq 'if length > 0 then .[-1] | {actor: .user.login, at: .submitted_at} else {actor: "", at: ""} end' 2>/dev/null || echo '{}')"

        # Compare timestamps to find most recent
        local comment_actor comment_at review_actor review_at
        comment_actor="$(printf '%s' "$comments_data" | jq -r '.actor // ""')"
        comment_at="$(printf '%s' "$comments_data" | jq -r '.at // ""')"
        review_actor="$(printf '%s' "$reviews_data" | jq -r '.actor // ""')"
        review_at="$(printf '%s' "$reviews_data" | jq -r '.at // ""')"

        if [ -n "$comment_at" ] && [ -n "$review_at" ]; then
            if [[ "$comment_at" > "$review_at" ]]; then
                last_actor="$comment_actor"
                last_at="$comment_at"
            else
                last_actor="$review_actor"
                last_at="$review_at"
            fi
        elif [ -n "$comment_at" ]; then
            last_actor="$comment_actor"
            last_at="$comment_at"
        elif [ -n "$review_at" ]; then
            last_actor="$review_actor"
            last_at="$review_at"
        fi
    else
        # For issues, just check comments
        local comments_data
        comments_data="$("$GH_REAL_BIN" api "repos/$repo/issues/$number/comments" \
            --jq 'if length > 0 then .[-1] | {actor: .user.login, at: .created_at} else {actor: "", at: ""} end' 2>/dev/null || echo '{}')"

        last_actor="$(printf '%s' "$comments_data" | jq -r '.actor // ""')"
        last_at="$(printf '%s' "$comments_data" | jq -r '.at // ""')"
    fi

    # If no comments/reviews, the author is effectively the last actor
    if [ -z "$last_actor" ]; then
        last_actor="__author__"
        last_at=""
    fi

    # Save to cache
    printf '{"updated_at":"%s","last_actor":"%s","last_at":"%s"}\n' \
        "$updated_at" "$last_actor" "$last_at" > "$cache_file"

    printf '%s\t%s\n' "$last_actor" "$last_at"
}

# Enrich items with last actor info (parallel)
enrich_with_last_actor() {
    local item_type repo number title url author updated_at is_draft my_role
    local running_jobs=0

    while IFS=$'\t' read -r item_type repo number title url author updated_at is_draft my_role; do
        [ -n "$repo" ] || continue

        (
            last_actor_data="$(get_last_actor "$item_type" "$repo" "$number" "$updated_at")"
            last_actor="$(printf '%s' "$last_actor_data" | cut -f1)"
            last_at="$(printf '%s' "$last_actor_data" | cut -f2)"

            # Determine if waiting on me
            local waiting_on_me="false"
            if [ "$last_actor" = "__author__" ]; then
                # No activity since creation
                if [ "$my_role" = "reviewer" ]; then
                    waiting_on_me="true"  # I need to review
                fi
            elif [ "$last_actor" != "$MY_USERNAME" ]; then
                waiting_on_me="true"  # Someone else acted last
            fi

            # Check if local
            local is_local="false"
            local local_path=""
            if repo_is_local "$repo"; then
                is_local="true"
                local_path="$(get_local_path "$repo")"
            fi

            printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
                "$item_type" "$repo" "$number" "$title" "$url" "$author" \
                "$updated_at" "$is_draft" "$my_role" "$last_actor" "$last_at" \
                "$waiting_on_me" "$is_local"
        ) &

        running_jobs=$((running_jobs + 1))
        if [ "$running_jobs" -ge "$JOBS" ]; then
            wait
            running_jobs=0
        fi
    done < "$GITHUB_ITEMS_FILE"

    if [ "$running_jobs" -gt 0 ]; then
        wait
    fi
}

# Calculate score for an item
# Input: type|repo|number|title|url|author|updated_at|is_draft|my_role|last_actor|last_at|waiting_on_me|is_local
calculate_score() {
    local item_type="$1"
    local updated_at="$2"
    local is_draft="$3"
    local my_role="$4"
    local waiting_on_me="$5"
    local is_local="$6"

    local score=0

    # Waiting on me: +500
    if [ "$waiting_on_me" = "true" ]; then
        score=$((score + 500))
    fi

    # Local repo: +200
    if [ "$is_local" = "true" ]; then
        score=$((score + 200))
    fi

    # Role scoring
    case "$my_role" in
        author)   score=$((score + 150)) ;;
        reviewer) score=$((score + 100)) ;;
        assignee) score=$((score + 75)) ;;
        *)        score=$((score + 25)) ;;
    esac

    # Recency score: 0-100, decays over time
    local days_ago recency_score
    if [ -n "$updated_at" ]; then
        local updated_epoch
        updated_epoch="$(date -j -f "%Y-%m-%dT%H:%M:%SZ" "$updated_at" +%s 2>/dev/null || \
                        date -d "$updated_at" +%s 2>/dev/null || echo "$NOW_EPOCH")"
        days_ago=$(( (NOW_EPOCH - updated_epoch) / 86400 ))
        recency_score=$((100 - days_ago * 10))
        if [ "$recency_score" -lt 0 ]; then
            recency_score=0
        fi
    else
        recency_score=50
    fi
    score=$((score + recency_score))

    # Draft penalty: -100
    if [ "$is_draft" = "true" ]; then
        score=$((score - 100))
    fi

    echo "$score"
}

# Score all enriched items
score_items() {
    local item_type repo number title url author updated_at is_draft my_role last_actor last_at waiting_on_me is_local

    while IFS=$'\t' read -r item_type repo number title url author updated_at is_draft my_role last_actor last_at waiting_on_me is_local; do
        [ -n "$repo" ] || continue

        local score
        score="$(calculate_score "$item_type" "$updated_at" "$is_draft" "$my_role" "$waiting_on_me" "$is_local")"

        printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
            "$score" "$item_type" "$repo" "$number" "$title" "$url" "$author" \
            "$updated_at" "$is_draft" "$my_role" "$last_actor" "$last_at" \
            "$waiting_on_me" "$is_local"
    done < "$ENRICHED_ITEMS_FILE" | sort -t $'\t' -k1,1nr
}

scan_local_repos() {
    local root gitdir repo_dir remote_url repo_name
    local roots_array=()

    IFS=':' read -r -a roots_array <<< "$ROOTS"
    for root in "${roots_array[@]}"; do
        [ -d "$root" ] || continue
        print_debug "Scanning root: $root"
        while IFS= read -r gitdir; do
            repo_dir="${gitdir%/.git}"
            remote_url="$(git -C "$repo_dir" config --get remote.origin.url 2>/dev/null || true)"
            repo_name="$(parse_github_repo "$remote_url")"
            [ -n "$repo_name" ] || continue
            printf "%s\t%s\n" "$repo_name" "$repo_dir" >> "$LOCAL_REPOS_FILE"
        done < <(find "$root" -maxdepth "$FIND_MAX_DEPTH" -type d -name .git -prune -print 2>/dev/null)
    done

    if [ -s "$LOCAL_REPOS_FILE" ]; then
        sort -u -t "$(printf '\t')" -k1,1 "$LOCAL_REPOS_FILE" -o "$LOCAL_REPOS_FILE"
    fi
}

cache_is_fresh() {
    local now mtime age

    if [ "$USE_REPO_CACHE" != "true" ]; then
        return 1
    fi

    if [ ! -f "$CACHE_REPOS_FILE" ] || [ ! -f "$CACHE_ROOTS_FILE" ]; then
        return 1
    fi

    if [ "$(cat "$CACHE_ROOTS_FILE" 2>/dev/null || true)" != "$(cache_key)" ]; then
        return 1
    fi

    now="$(date +%s)"
    mtime="$(file_mtime "$CACHE_REPOS_FILE")"
    age=$((now - mtime))

    [ "$age" -le "$REPO_CACHE_TTL" ]
}

load_repo_cache() {
    if cache_is_fresh; then
        print_debug "Using repo cache: $CACHE_REPOS_FILE"
        cp "$CACHE_REPOS_FILE" "$LOCAL_REPOS_FILE"
        return 0
    fi
    return 1
}

save_repo_cache() {
    if [ "$USE_REPO_CACHE" != "true" ]; then
        return 0
    fi

    mkdir -p "$CACHE_DIR"
    cp "$LOCAL_REPOS_FILE" "$CACHE_REPOS_FILE"
    cache_key > "$CACHE_ROOTS_FILE"
}

# Format a single item for display
format_item() {
    local score="$1"
    local item_type="$2"
    local repo="$3"
    local number="$4"
    local title="$5"
    local url="$6"
    local author="$7"
    local updated_at="$8"
    local is_draft="$9"
    local my_role="${10}"
    local last_actor="${11}"
    local waiting_on_me="${12}"
    local is_local="${13}"

    local type_icon updated_date role_label local_marker draft_marker last_info

    # Type icon
    if [ "$item_type" = "pr" ]; then
        type_icon="PR"
    else
        type_icon="Issue"
    fi

    # Updated date (just date part)
    updated_date="${updated_at:0:10}"

    # Role label
    case "$my_role" in
        author)   role_label="author" ;;
        reviewer) role_label="reviewer" ;;
        assignee) role_label="assignee" ;;
        *)        role_label="involved" ;;
    esac

    # Local marker
    if [ "$is_local" = "true" ]; then
        local_marker=" 📂"
    else
        local_marker=""
    fi

    # Draft marker
    if [ "$is_draft" = "true" ]; then
        draft_marker=" [draft]"
    else
        draft_marker=""
    fi

    # Last actor info
    if [ "$last_actor" = "__author__" ]; then
        last_info="no activity since created"
    elif [ "$last_actor" = "$MY_USERNAME" ]; then
        last_info="you acted last"
    else
        last_info="@$last_actor acted last"
    fi

    printf "  ${DIM}%s${NC} ${BOLD}%s${NC} #%s%s%s\n" "$updated_date" "$repo" "$number" "$local_marker" "$draft_marker"
    printf "    %s\n" "$title"
    printf "    ${DIM}%s · %s · %s${NC}\n" "$type_icon" "$role_label" "$last_info"
    printf "    %s\n" "$url"
}

# Render the action needed section
render_action_needed() {
    local count=0
    local score item_type repo number title url author updated_at is_draft my_role last_actor last_at waiting_on_me is_local

    echo
    print_color "$RED" "🔴 ACTION NEEDED (waiting on you)"
    echo

    while IFS=$'\t' read -r score item_type repo number title url author updated_at is_draft my_role last_actor last_at waiting_on_me is_local; do
        [ -n "$repo" ] || continue
        [ "$waiting_on_me" = "true" ] || continue

        format_item "$score" "$item_type" "$repo" "$number" "$title" "$url" "$author" \
            "$updated_at" "$is_draft" "$my_role" "$last_actor" "$waiting_on_me" "$is_local"
        echo
        count=$((count + 1))
    done < "$SCORED_ITEMS_FILE"

    if [ "$count" -eq 0 ]; then
        echo "  (none - you're all caught up!)"
        echo
    fi
}

